#include <iostream>
#include <vector>
using namespace std;
class node{
	int data;
	node* left,*right;
public:
	node(int data=0){
		this->data=data;
		left=right=NULL;
	}
	friend class TBT;
};
class TBT{
public:
	node* root=NULL;
	void insert(node* &root){
		cout<<"enter data ";
		int x;cin>>x;
		node* par;
		if(root==NULL){
			if(x!=-1){root=new node(x);}
			else{root=NULL;}

		}
		else{
			node* temp=root;
			while(temp!=NULL){
				par=temp;
				if(temp->data >x){
					temp=temp->left;
					if(!temp){
						par->left=new node(x);
						return;
					}
				}
				else if(temp->data < x){
					temp=temp->right;
					if(!temp){
						par->right=new node(x);
						return;
					}
				}
			}
		}
	}

	void inOrder(node* root){
		if(root==NULL){return;}
		inOrder(root->left);
		cout<<root->data<<" ";
		inOrder(root->right);
	}

